# DeepWiki Plugin UI - Local Development Environment Variables

# Remote Elitea Server Configuration
# Replace with your Elitea instance URL (e.g., https://dev.elitea.ai or http://localhost:8080)
VITE_DEV_SERVER=https://dev.elitea.ai

# API Configuration
# Base path for API requests (usually /api/v2)
VITE_SERVER_URL=/api/v2

# Socket.IO Configuration
# Path for WebSocket connections
VITE_SOCKET_PATH=/socket.io/
# Socket.IO server URL (usually same as VITE_DEV_SERVER)
VITE_SOCKET_SERVER=https://dev.elitea.ai

# Authentication (Optional)
# If your server requires authentication token for development
# Get this from your browser's DevTools > Application > Cookies > token
# VITE_DEV_TOKEN=your-jwt-token-here

# Project Configuration (Optional)
# Default project ID to use when testing
# VITE_DEFAULT_PROJECT_ID=5

# Toolkit Configuration (Optional)  
# Default toolkit ID to use when testing the UI
# VITE_DEFAULT_TOOLKIT_ID=42

# Theme (Optional)
# Default theme to use: 'light' or 'dark'
# VITE_DEFAULT_THEME=light
