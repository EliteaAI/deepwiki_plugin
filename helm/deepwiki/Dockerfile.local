# Dockerfile for local minikube testing
# This builds an image with deepwiki_plugin pre-installed (matching docker-compose setup)
#
# Usage:
#   eval $(minikube docker-env)
#   docker build -f helm/deepwiki/Dockerfile.local -t deepwiki-local:latest .
#   helm upgrade deepwiki ./helm/deepwiki -n deepwiki \
#     --set image.repository=deepwiki-local \
#     --set image.tag=latest \
#     --set image.pullPolicy=Never \
#     --set config.skipBootstrap=true

FROM getcarrier/pylon:1.2.7

# Create necessary directories
RUN mkdir -p /data/plugins /data/requirements /data/configs /data/cache/pip /data/wiki_builder

# Copy bootstrap plugin (required for pylon initialization)
COPY pylon_deepwiki/plugins/bootstrap /data/plugins/bootstrap

# Copy the deepwiki plugin
COPY pylon_deepwiki/plugins/deepwiki_plugin /data/plugins/deepwiki_plugin

# Copy pre-installed requirements (includes networkx, langchain, etc.)
COPY pylon_deepwiki/requirements/bootstrap /data/requirements/bootstrap
COPY pylon_deepwiki/requirements/bootstrap.json /data/requirements/bootstrap.json
COPY pylon_deepwiki/requirements/deepwiki_plugin /data/requirements/deepwiki_plugin
COPY pylon_deepwiki/requirements/deepwiki_plugin.json /data/requirements/deepwiki_plugin.json

# Copy configs
COPY pylon_deepwiki/configs /data/configs

# Set ownership to www-data (uid 33)
RUN chown -R 33:33 /data

# Verify networkx is properly installed
RUN python3 -c "import sys; sys.path.insert(0, '/data/requirements/deepwiki_plugin/lib/python3.12/site-packages'); import networkx as nx; print('networkx OK:', nx.__version__)"
